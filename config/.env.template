# =============================================
# F.R.I.D.A.Y. v2 — Environment Variables
# =============================================
# Copy this file to .env and customize:
#   cp config/.env.template .env

# Project paths
FRIDAY_HOME=/Users/YOURNAME/PycharmProjects/Friday
FRIDAY_MODELS=/Users/YOURNAME/PycharmProjects/Friday/models
FRIDAY_MAX_MEMORY_GB=3.5

# Feature toggles
ENABLE_MEMORY_MONITORING=true
ENABLE_WAKE_WORD=true
ENABLE_FACE_RECOGNITION=true

# Logging
LOG_LEVEL=INFO

# Security
MEMORY_ENCRYPTION_KEY=  # Leave blank to auto-generate from machine fingerprint
ALLOWED_DIRECTORIES=~/Documents,~/Desktop

# Hindi/Bilingual (Phase 9+)
ENABLE_HINDI_STT=false
SARVAM_API_KEY=  # Only needed if ENABLE_HINDI_STT=true
